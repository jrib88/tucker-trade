---
import BrandIcon from './BrandIcon.astro'
import { getAudioEmbed } from '../data/audio-embed'
import type { SiteData } from '../data/types'

interface Props {
  music: SiteData['music']
}

const { music } = Astro.props
const featuredTrack = music.featuredTrack
const audioEmbed = getAudioEmbed(featuredTrack?.url)
const iframeTitle = featuredTrack?.title ? `${featuredTrack.title} audio player` : `Featured audio on ${audioEmbed?.provider}`
const playerClass = audioEmbed?.kind === 'single' ? 'music-player music-player--single' : 'music-player'
---

<section class="music" id="music" aria-labelledby="music-heading">
  <div class="music-columns">
    <div class="music-copy">
      <h2 id="music-heading">Music</h2>
      <h3>Listen to Tucker's Tunes on:</h3>
      <div class="music-links">
        {music.links.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={`Listen on ${link.label}`} title={link.label}>
            <BrandIcon platform={link.platform} label={link.label} />
          </a>
        ))}
      </div>
    </div>
    <div class={playerClass} aria-label={featuredTrack?.title ?? 'Featured audio'}>
      {audioEmbed ? (
        <iframe
          title={iframeTitle}
          src={audioEmbed.src}
          loading="lazy"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          allowfullscreen
        ></iframe>
      ) : featuredTrack?.url && (
        <a class="music-player-fallback" href={featuredTrack.url} target="_blank" rel="noopener noreferrer">
          {featuredTrack.title ?? 'Open featured audio'}
        </a>
      )}
    </div>
  </div>
</section>

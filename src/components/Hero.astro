---
import type { SiteData } from '../data/types'
import SanityImage from './SanityImage.astro'

interface Props {
  artistName: string
  hero: SiteData['hero']
  hasMusic: boolean
  hasContact: boolean
}

const { artistName, hero, hasMusic, hasContact } = Astro.props
const records = hero.recordImages ?? []
const artistLabel = 'Artist Label: Flaunt the Frequency'
---

<section class="home" id="home" aria-label="Home">
  <div class="source-logo" aria-label={artistName}>
    <img src="/assets/tt-logo.png" alt={artistName} width="3024" height="550" loading="eager" decoding="async" />
  </div>
  <p class="artist-label-banner">{artistLabel}</p>

  <div class="portrait-hero">
    <SanityImage
      image={hero.backgroundImage}
      fallbackSrc="/assets/home-09-9f2961cb6c.png"
      class="portrait-hero__background"
      width={1451}
      height={722}
      loading="eager"
    />
    <SanityImage
      image={hero.portraitImage}
      fallbackSrc="/assets/home-10-478bd8530b.png"
      fallbackAlt={`${artistName} in sunglasses and a cap`}
      class="portrait-hero__artist"
      width={1920}
      height={2560}
      loading="eager"
    />
  </div>

  <div class="home-intro">
    <h1>{hero.heading}</h1>
    <p>{hero.intro}</p>
  </div>

  <SanityImage
    image={hero.performanceImage}
    fallbackSrc="/assets/home-18-e700edfc75.jpg"
    fallbackAlt={`${artistName} performing on DJ decks`}
    class="dj-photo"
    width={1182}
    height={665}
  />

  <div class="records">
    <a class="record-link" href={hasMusic ? '#music' : '#shows'}>
      <SanityImage image={records[0]} fallbackSrc="/assets/home-12-6b0c547bd1.png" class="matte-image" width={2130} height={2132} />
      <span class="record-link__label">Listen</span>
    </a>
    <a class="record-link" href={hasContact ? '#contact' : '#shows'}>
      <SanityImage image={records[0]} fallbackSrc="/assets/home-12-6b0c547bd1.png" class="matte-image" width={2130} height={2132} />
      <span class="record-link__label record-link__label--book">Book &amp; contact</span>
    </a>
  </div>
</section>

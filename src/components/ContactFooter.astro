---
import BrandIcon from './BrandIcon.astro'
import type { Link } from '../data/types'

interface Props {
  artistName: string
  email?: string
  heading?: string
  links: Link[]
}

const { artistName, email, heading = 'Booking / Contact', links } = Astro.props
---

<footer class="contact-footer" id="contact" aria-labelledby="contact-heading">
  <h2 id="contact-heading">{heading}</h2>
  {email && (
    <p class="contact-copy">
      For all inquiries, bookings, collaborations, and press, email <a href={`mailto:${email}`}>{email}</a>.
    </p>
  )}
  <div class="contact-footer__bottom">
    <p class="contact-footer__copyright">© {new Date().getFullYear()} {artistName}</p>
    {links.length > 0 && (
      <nav class="contact-links" aria-label="Social links">
        {links.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label}>
            <BrandIcon platform={link.platform} label={link.label} />
          </a>
        ))}
      </nav>
    )}
  </div>
</footer>

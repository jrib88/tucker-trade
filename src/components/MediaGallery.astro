---
import type { MediaItem } from '../data/types'
import SanityImage from './SanityImage.astro'

interface Props {
  items: MediaItem[]
}

const { items } = Astro.props
---

{items.length > 0 && (
  <section class="media-section press-section" id="press" aria-labelledby="press-heading">
    <h2 id="press-heading">Press</h2>
    <div class="press-grid">
      {items.map((item) => (
        <article class="press-card">
          {item.link?.url ? (
            <a href={item.link.url} target="_blank" rel="noopener noreferrer">
              <SanityImage image={item.image} fallbackAlt={item.title ?? ''} width={900} height={700} />
            </a>
          ) : (
            <SanityImage image={item.image} fallbackAlt={item.title ?? ''} width={900} height={700} />
          )}
          {item.title && <h3>{item.title}</h3>}
          {item.caption && <p>{item.caption}</p>}
          {item.link?.url && <a class="text-link" href={item.link.url} target="_blank" rel="noopener noreferrer">{item.link.label || 'Read more'}</a>}
        </article>
      ))}
    </div>
  </section>
)}

---
import '../styles/global.css'

interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/assets/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/assets/site.webmanifest" />
    <meta name="theme-color" content="#111110" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header" data-site-header>
      <div class="site-header__inner">
        <a class="site-brand" href="#home" aria-label={title} aria-hidden="true" tabindex="-1" data-site-brand>
          <img src="/assets/tt-logo.png" alt="" width="3024" height="550" loading="eager" decoding="async" />
        </a>
        <button class="site-menu-toggle" type="button" aria-label="Open menu" aria-controls="site-navigation" aria-expanded="false" data-menu-toggle>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
        <nav class="site-nav" id="site-navigation" aria-label="Primary navigation" data-site-nav>
          <a href="#home">Home</a>
          <a href="#music">Music</a>
          <a href="#shows">Live</a>
          <a href="#contact">Booking / Contact</a>
        </nav>
      </div>
    </header>
    <main id="main-content"><slot /></main>
    <script>
      const header = document.querySelector('[data-site-header]')
      const brand = document.querySelector('[data-site-brand]')
      const nav = document.querySelector('[data-site-nav]')
      const menuToggle = document.querySelector('[data-menu-toggle]')
      const heroLogo = document.querySelector('.source-logo')
      const mobileMenuQuery = window.matchMedia('(max-width: 720px)')
      let isTicking = false

      function updateNavShift() {
        if (!(header instanceof HTMLElement) || !nav) return

        const headerRect = header.getBoundingClientRect()
        const navRect = nav.getBoundingClientRect()
        const headerInner = header.querySelector('.site-header__inner')
        const headerStyles = headerInner ? window.getComputedStyle(headerInner) : null
        const paddingRight = headerStyles ? Number.parseFloat(headerStyles.paddingRight) || 0 : 0
        const targetShift = Math.max(0, (headerRect.width / 2) - paddingRight - (navRect.width / 2))

        header.style.setProperty('--site-nav-shift', `${targetShift}px`)
      }

      function setMenuOpen(isOpen: boolean) {
        if (!(header instanceof HTMLElement) || !(menuToggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) return

        const canUseCollapsedMenu = mobileMenuQuery.matches && header.classList.contains('site-header--mobile-collapsed')
        const nextOpen = Boolean(isOpen && canUseCollapsedMenu)

        header.classList.toggle('site-header--menu-open', nextOpen)
        menuToggle.setAttribute('aria-expanded', String(nextOpen))
        menuToggle.setAttribute('aria-label', nextOpen ? 'Close menu' : 'Open menu')

        if (canUseCollapsedMenu) {
          nav.setAttribute('aria-hidden', String(!nextOpen))
        } else {
          nav.removeAttribute('aria-hidden')
        }
      }

      function updateHeaderState() {
        if (!(header instanceof HTMLElement)) return
        updateNavShift()

        const hasPassedHeroLogo = heroLogo
          ? heroLogo.getBoundingClientRect().bottom <= header.getBoundingClientRect().height + 1
          : window.scrollY > 16

        header.classList.toggle('site-header--scrolled', hasPassedHeroLogo)
        header.classList.toggle('site-header--mobile-collapsed', mobileMenuQuery.matches && window.scrollY > 16)

        if (brand) {
          if (hasPassedHeroLogo) {
            brand.removeAttribute('aria-hidden')
            brand.removeAttribute('tabindex')
          } else {
            brand.setAttribute('aria-hidden', 'true')
            brand.setAttribute('tabindex', '-1')
          }
        }

        setMenuOpen(header.classList.contains('site-header--menu-open'))
      }

      function requestHeaderUpdate() {
        if (isTicking) return

        isTicking = true
        window.requestAnimationFrame(() => {
          updateHeaderState()
          isTicking = false
        })
      }

      if (menuToggle instanceof HTMLButtonElement) {
        menuToggle.addEventListener('click', () => {
          if (!(header instanceof HTMLElement)) return
          setMenuOpen(!header.classList.contains('site-header--menu-open'))
        })
      }

      if (nav instanceof HTMLElement) {
        nav.addEventListener('click', (event) => {
          if (event.target instanceof HTMLAnchorElement) {
            setMenuOpen(false)
          }
        })
      }

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setMenuOpen(false)
        }
      })

      const handleMobileMenuQueryChange = () => {
        setMenuOpen(false)
        requestHeaderUpdate()
      }

      if (typeof (mobileMenuQuery as unknown as { addEventListener?: unknown }).addEventListener === 'function') {
        mobileMenuQuery.addEventListener('change', handleMobileMenuQueryChange)
      } else {
        const legacyMobileMenuQuery = mobileMenuQuery as unknown as { addListener: (listener: () => void) => void }
        legacyMobileMenuQuery.addListener(handleMobileMenuQueryChange)
      }

      updateHeaderState()
      window.addEventListener('load', updateHeaderState)
      window.addEventListener('resize', requestHeaderUpdate)
      window.addEventListener('scroll', requestHeaderUpdate, { passive: true })
    </script>
  </body>
</html>
